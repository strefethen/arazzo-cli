{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ValidateResult",
  "type": "object",
  "properties": {
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ValidateIssue"
      }
    },
    "file": {
      "type": "string"
    },
    "sources": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "valid": {
      "type": "boolean"
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    },
    "workflows": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0
    }
  },
  "required": [
    "valid",
    "file"
  ],
  "$defs": {
    "ValidateIssue": {
      "type": "object",
      "properties": {
        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "source",
        "message"
      ]
    }
  }
}
