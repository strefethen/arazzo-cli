{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunOutput",
  "description": "Combined schema type for the `run` command output.\n\nThe actual shape depends on flags and exit code:\n- `Success`: `{\"kind\":\"success\",\"outputs\":{...},\"warnings\":[...]?}` (exit 0, no `--dry-run`)\n- `Error`: `{\"kind\":\"error\",\"error\":\"...\",\"code\":\"...\",\"warnings\":[...]?}` (non-zero exit)\n- `DryRun`: `{\"kind\":\"dryRun\",\"requests\":[...],\"warnings\":[...]?}` (exit 0, `--dry-run`)",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "success"
        },
        "outputs": {
          "type": "object",
          "additionalProperties": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "kind",
        "outputs"
      ]
    },
    {
      "type": "object",
      "properties": {
        "code": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "error"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "kind",
        "error"
      ]
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "dryRun"
        },
        "requests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DryRunRequest"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "kind",
        "requests"
      ]
    }
  ],
  "$defs": {
    "DryRunRequest": {
      "description": "Captured request emitted during dry-run mode.",
      "type": "object",
      "properties": {
        "body": true,
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "method": {
          "type": "string"
        },
        "stepId": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "stepId",
        "method",
        "url"
      ]
    }
  }
}
