{
  "name": "arazzo-debug",
  "displayName": "Arazzo Debugger",
  "description": "Debug Arazzo workflow files with breakpoints and step controls.",
  "version": "0.0.1",
  "publisher": "strefethen",
  "license": "MIT",
  "preview": true,
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/strefethen/arazzo-cli"
  },
  "homepage": "https://github.com/strefethen/arazzo-cli/tree/main/vscode-arazzo-debug",
  "bugs": {
    "url": "https://github.com/strefethen/arazzo-cli/issues"
  },
  "keywords": [
    "arazzo",
    "debugger",
    "openapi",
    "workflow",
    "api",
    "dap",
    "yaml"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:arazzo",
    "onLanguage:arazzo"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "arazzo",
        "aliases": ["Arazzo", "arazzo"],
        "extensions": [".arazzo.yaml", ".arazzo.yml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arazzo",
        "scopeName": "source.arazzo",
        "path": "./syntaxes/arazzo.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "arazzo"
      }
    ],
    "debuggers": [
      {
        "type": "arazzo",
        "label": "Arazzo",
        "languages": [
          "arazzo"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "spec"
            ],
            "properties": {
              "spec": {
                "type": "string",
                "description": "Path to the .arazzo.yaml file."
              },
              "workflowId": {
                "type": "string",
                "description": "Workflow id to execute."
              },
              "inputs": {
                "type": "object",
                "description": "Input key/value map passed to workflow execution.",
                "default": {}
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause immediately at workflow entry before the first step.",
                "default": false
              },
              "runtimeExecutable": {
                "type": "string",
                "description": "Command used to launch the Rust debug adapter."
              },
              "runtimeArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Args used to launch the Rust debug adapter."
              },
              "runtimeCwd": {
                "type": "string",
                "description": "Working directory used to launch the Rust debug adapter."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "arazzo",
            "request": "launch",
            "name": "Debug Arazzo Workflow",
            "spec": "${file}",
            "workflowId": "",
            "inputs": {}
          }
        ],
        "configurationSnippets": [
          {
            "label": "Arazzo: Debug Workflow",
            "description": "Debug an Arazzo workflow spec.",
            "body": {
              "type": "arazzo",
              "request": "launch",
              "name": "Debug ${1:workflow-name}",
              "spec": "^\"\\${file}\"",
              "workflowId": "${2:workflow-id}",
              "inputs": {}
            }
          },
          {
            "label": "Arazzo: Debug with Stop on Entry",
            "description": "Debug an Arazzo workflow, pausing at entry.",
            "body": {
              "type": "arazzo",
              "request": "launch",
              "name": "Debug ${1:workflow-name} (stop on entry)",
              "spec": "^\"\\${file}\"",
              "workflowId": "${2:workflow-id}",
              "inputs": {},
              "stopOnEntry": true
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build && node scripts/copy-binary.js",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p .",
    "watch": "tsc -w -p .",
    "lint": "tsc -p . --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
